{
  "id": "open-webui",
  "version": "0.1.1",
  "api_version": "1",
  "type": "ui_extension",
  "title": "Open WebUI",
  "description": "Removable iframe tab and Docker runtime owner for Open WebUI.",
  "icon": "icons/open-webui-light.svg",
  "tab_ui": {
    "title": "Open WebUI",
    "icon": "icons/open-webui-light.svg",
    "frame": {
      "id": "open-webui-iframe-frame",
      "type": "iframe",
      "chrome": "open-webui-service",
      "asset_scope": "extension"
    }
  },
  "backend": {
    "entrypoint": "backend.provider:create_provider"
  },
  "capabilities": {
    "tab_ui": true,
    "iframe_tab": true,
    "service_actions": true
  },
  "compatibility": {
    "app": "chironai",
    "extension_api_version": "1"
  },
  "settings_schema": {
    "title": "Open WebUI Settings",
    "fields": []
  },
  "ui_schema": {},
  "metadata": {
    "service": "open-webui"
  }
}
