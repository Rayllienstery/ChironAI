{
  "name": "default",
  "steps": [
    {
      "id": "strip-meta",
      "type": "strip_meta_block",
      "params": {}
    },
    {
      "id": "delete-boilerplate-exact",
      "type": "delete_lines_exact",
      "params": {
        "lines": [
          "View in English",
          "View in Russian",
            "In English",
            "In Russian",
          "Table of Contents",
          "Contents",
          "Download video",
          "Download Video",
          "Download",
          "Share",
          "Add to favorites",
          "Add to Favorites",
          "Favorite",
          "Up Next"
        ],
        "case_sensitive": false
      }
    },
    {
      "id": "delete-view-links",
      "type": "delete_lines_containing",
      "params": {
        "substrings": ["view in english", "view in russian"],
        "case_sensitive": false
      }
    },
    {
      "id": "normalize-ws",
      "type": "normalize_whitespace",
      "params": {}
    },
    {
      "id": "wrap-swift-indented-code",
      "type": "wrap_indented_code",
      "params": {
        "language": "swift",
        "min_block_lines": 2
      }
    },
    {
      "id": "strip-noise-sections",
      "type": "strip_sections_by_heading",
      "params": {
        "headings": [
          "conforming types",
          "inherited by",
          "inherits from",
          "relationships"
        ]
      }
    },
    {
      "id": "reject-low-signal",
      "type": "reject_low_signal_body",
      "params": {
        "min_chars": 120,
        "min_words": 5,
        "min_alpha_ratio": 0.12
      }
    }
  ]
}
