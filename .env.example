# ChironAI environment variables example
# Copy this file to .env and uncomment/adjust values for your local setup.
# For precedence rules see Core/config/CONFIG_AUTHORITY.md.
# For a flat variable index see Core/config/ENV_REFERENCE.md.

# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------
# SERVER_HOST=127.0.0.1
# SERVER_HOST=0.0.0.0
# SERVER_PORT=8080
# WEBUI_PORT=5000
# LOG_LEVEL=INFO
# LOG_FORMAT=text

# ---------------------------------------------------------------------------
# Qdrant
# ---------------------------------------------------------------------------
# QDRANT_URL=http://localhost:6333
# QDRANT_COLLECTION_NAME=Apple_Collection
# QDRANT_CONTAINER_NAME=qdrant

# ---------------------------------------------------------------------------
# Ollama (provider-owned endpoints used by the bundled ollama-provider)
# ---------------------------------------------------------------------------
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_CHAT_URL=http://localhost:11434/api/chat
# OLLAMA_URL=http://localhost:11434/api/generate
# OLLAMA_EMBED_URL=http://localhost:11434/api/embed
# OLLAMA_CHAT_MODEL=llama3.1
# OLLAMA_RERANK_MODEL=bbjson/bge-reranker-base
# RAG_EMBED_MODEL=mxbai-embed-large
# OLLAMA_EMBED_TIMEOUT=180
# OLLAMA_PORT=11434
# OLLAMA_CONTAINER_NAME=chironai-ollama
# OLLAMA_DOCKER_IMAGE=ollama/ollama:latest
# OLLAMA_DOCKER_VOLUME=ollama_models:/root/.ollama
# OLLAMA_DOCKER_RESTART=unless-stopped

# ---------------------------------------------------------------------------
# RAG / retrieval
# ---------------------------------------------------------------------------
# RAG_PROMPT=system_rag_v1
# RAG_CONTEXT_CHUNK_CHARS=1000
# RAG_CONTEXT_TOTAL_CHARS=7000
# RAG_TOP_K=8
# DEFAULT_RAG_TOP_K=4
# FRAMEWORK_COLLECTION_TTL_DAYS=90

# ---------------------------------------------------------------------------
# Extensions / GitHub
# ---------------------------------------------------------------------------
# CHIRONAI_EXTENSIONS_REGISTRY_URL=https://raw.githubusercontent.com/Rayllienstery/ChironAI-Extensions-Registry/main/extensions.json
# CHIRONAI_EXTENSIONS_LOCAL_REGISTRY_FALLBACK=extensions/registry/extensions.json
# CHIRONAI_EXTENSIONS_BLOCKLIST_URL=https://raw.githubusercontent.com/Rayllienstery/ChironAI-Extensions-Registry/main/blocklist.json
# CHIRONAI_EXTENSIONS_LOCAL_BLOCKLIST_FALLBACK=extensions/registry/blocklist.json
# CHIRONAI_GITHUB_TOKEN=

# ---------------------------------------------------------------------------
# LLM Proxy
# ---------------------------------------------------------------------------
# LLM_PROXY_V1_INCLUDE_AUTOCOMPLETE_MODEL=true
# LLM_PROXY_AUTOCOMPLETE_OLLAMA_MODEL=
# LLM_PROXY_AUTOCOMPLETE_MODEL_ID=
# LLM_PROXY_VISION_FALLBACK_MODEL=
# LLM_PROXY_VISION_FETCH_EXTERNAL_URLS=0
# LLM_PROXY_VISION_READ_LOCAL_FILES=0
# LLM_PROXY_VISION_ALLOW_ABS_PATHS=0

# ---------------------------------------------------------------------------
# Service URLs (when running services separately, e.g. docker-compose)
# ---------------------------------------------------------------------------
# RAG_SERVICE_URL=http://localhost:5001
# MD_INGESTION_SERVICE_URL=http://localhost:5002
# CRAWLER_SERVICE_URL=http://localhost:5003

# ---------------------------------------------------------------------------
# WebUI / database paths
# ---------------------------------------------------------------------------
# WEBUI_DB_PATH=logs/webui.db
# CHIRONAI_WEBUI_DIR=WebUI
# CHIRONAI_PROJECT_ROOT=.
# CHIRONAI_OPEN_BROWSER=1

# ---------------------------------------------------------------------------
# Web interaction
# ---------------------------------------------------------------------------
# WEB_INTERACTION_WIKIPEDIA=1
# WEB_INTERACTION_FETCH_PAGE=1
# WEB_INTERACTION_MAX_RESULTS=5
# WEB_INTERACTION_CACHE_TTL_S=3600
# WEB_INTERACTION_PREFERRED_DOMAINS=
# WEB_INTERACTION_DDG_NEWS=0
# WEB_INTERACTION_DDG_REGION=wt-wt

# ---------------------------------------------------------------------------
# Open WebUI extension (bundled)
# ---------------------------------------------------------------------------
# OPEN_WEBUI_URL=http://localhost:3000
# OPEN_WEBUI_HOST_PORT=3000
# OPEN_WEBUI_CONTAINER_PORT=8080
# OPEN_WEBUI_CONTAINER_NAME=open-webui
# OPEN_WEBUI_IMAGE=ghcr.io/open-webui/open-webui:main
# OPEN_WEBUI_DATA_VOLUME=open-webui
# OPEN_WEBUI_OLLAMA_BASE_URL=http://host.docker.internal:11434

# ---------------------------------------------------------------------------
# RAG runtime / Docker tuning
# ---------------------------------------------------------------------------
# QDRANT_HOST_HTTP_PORT=6333
# QDRANT_HOST_GRPC_PORT=6334
# QDRANT_IMAGE=qdrant/qdrant:v1.12.5
# RAG_RUNTIME_DOCKER_READY_TIMEOUT=120
# RAG_RUNTIME_DOCKER_POLL_INTERVAL=5
# RAG_RUNTIME_HTTP_WAIT_TIMEOUT=60
# DOCKER_EXE=docker

# ---------------------------------------------------------------------------
# Optional: override default LLM provider id
# ---------------------------------------------------------------------------
# DEFAULT_LLM_PROVIDER_ID=ollama

# ---------------------------------------------------------------------------
# Optional: RAG keywords / tests
# ---------------------------------------------------------------------------
# RAG_KEYWORDS_DB_PATH=logs/rag_keywords.db
# RAG_TESTS_ROOT=rag_tests
# RAG_TESTS_VALIDATION_MODE=strict
# RAG_VERBOSE_LOGS=0
# MD_INDEXER_PIPELINE=default
